# ============================================================
#  STITCH SMART — Railway Production Environment
#
#  These values are overridden at runtime by the environment
#  variables set in the Railway dashboard. Empty placeholders
#  are safe: config.php only writes a key from this file when
#  it is NOT already present in $_ENV (Railway injects first).
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME=Stitch Smart
APP_ENV=production
APP_DEBUG=false
APP_URL=

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_NAME=

# ── Admin Credentials ────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Google Gemini AI API ─────────────────────────────────────
GOOGLE_API_KEY=

# ── FAISS / Vector Search ────────────────────────────────────
FAISS_INDEX_PATH=faiss_index
FAISS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chatbot Service ──────────────────────────────────────────
CHATBOT_API_URL=
CHATBOT_API_TIMEOUT=10

# ── Email (PHPMailer / SMTP) ─────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=Stitch Smart

# ── Session ──────────────────────────────────────────────────
SESSION_LIFETIME=7200
