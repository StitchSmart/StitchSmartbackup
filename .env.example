# ============================================================
#  STITCH SMART - Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  DO NOT commit .env — it is listed in .gitignore.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME="Stitch Smart"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000/

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=StitchSmart
DB_USER=root
DB_PASS=

# ── Admin Credentials (initial seed — change after first login)
ADMIN_EMAIL=admin@stitchsmart.com
ADMIN_PASSWORD=change_me_immediately

# ── Google Gemini AI API ─────────────────────────────────────
# Get a free key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── FAISS / Vector Search ────────────────────────────────────
FAISS_INDEX_PATH=faiss_index
FAISS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chatbot Service ──────────────────────────────────────────
CHATBOT_API_URL=http://localhost:5000
CHATBOT_API_TIMEOUT=10

# ── Email (PHPMailer / SMTP) ─────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Stitch Smart"

# ── Session ──────────────────────────────────────────────────
SESSION_LIFETIME=7200
